NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/bundlebee

# Auth/session secrets
SESSION_SECRET=replace_with_a_secure_random_string
JWT_SECRET=replace_with_a_secure_random_string
JWT_REFRESH_SECRET=replace_with_a_secure_random_string
JWT_OTP_SECRET=replace_with_a_secure_random_string

# Browser/API URLs
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
COOKIE_DOMAIN=
COOKIE_NAME=sid
DEBUG_2FA_CONTEXT=

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Admin bootstrap/check used by Google OAuth flow
EMAIL_USER=admin@example.com

# Zoho email. Required in production for email delivery.
EMAIL_ZOHO=
PASS_ZOHO=

# Legacy/general SMTP vars. These are present in production config but current mail code uses EMAIL_ZOHO/PASS_ZOHO.
EMAIL_HOST=smtp.zoho.eu
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_PASS=

# Optional external frontend/deployment URL used outside current backend code paths.
CLOUDFLARE_WORKER_URL=

# Optional MongoDB FLE key. Current db config logs that FLE is not enabled.
MONGO_FLE_MASTER_KEY=

# S3 invoice/expense storage. Required for accounting file upload/signing paths.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
