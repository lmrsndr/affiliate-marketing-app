NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/bundlebee

# Supabase Auth (active administrator authentication)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me

# Legacy auth/session values retained temporarily for rollback during migration
SESSION_SECRET=replace_with_a_secure_random_string
JWT_SECRET=replace_with_a_secure_random_string
JWT_REFRESH_SECRET=replace_with_a_secure_random_string
JWT_OTP_SECRET=replace_with_a_secure_random_string

# Browser/API URLs
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
COOKIE_DOMAIN=
COOKIE_NAME=sid
DEBUG_2FA_CONTEXT=

# Legacy Google OAuth values retained until Supabase Google sign-in is enabled
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
EMAIL_USER=admin@example.com

# Legacy email delivery retained only for rollback/password-recovery code paths
EMAIL_ZOHO=
PASS_ZOHO=
EMAIL_HOST=smtp.zoho.eu
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_PASS=

# Optional deployment URL
CLOUDFLARE_WORKER_URL=

# Optional MongoDB FLE key
MONGO_FLE_MASTER_KEY=

# Legacy storage values retained until dependency cleanup is complete
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
